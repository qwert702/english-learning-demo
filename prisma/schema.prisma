datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String?  @unique
  password  String?
  image     String?
  level     String?
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts        Account[]
  sessions        Session[]
  learningRecords LearningRecord[]
  progress        UserProgress?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Article {
  id        String   @id @default(cuid())
  title     String
  content   String
  level     String
  category  String
  grade     String?
  audioUrl  String?
  source      String  @default("ai_generated")
  sourceUrl   String?
  sourceLabel String?
  wordCount Int
  isPublic  Boolean  @default(false)
  sentences String   @default("[]")
  type      String   @default("EXTRA")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questions       ComprehensionQuestion[]
  learningRecords LearningRecord[]

  @@index([type])
  @@index([level])
  @@index([type, level])
}

model ComprehensionQuestion {
  id          String  @id @default(cuid())
  articleId   String
  question    String
  options     String  @default("[]")
  correct     String
  explanation String?
  order       Int
  createdAt   DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
}

model LearningRecord {
  id        String   @id @default(cuid())
  userId    String
  articleId String?
  type      String
  detail    String   @default("{}")
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)
}

model UserProgress {
  id        String   @id @default(cuid())
  userId    String   @unique
  streakDays    Int      @default(0)
  totalStudyMin Int      @default(0)
  lastStudyDate DateTime?
  level     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── 全局站点配置（单例模式） ─────────────────────────────────

model SiteConfig {
  id               String   @id @default("global")
  disabledFeatures String   @default("[]")
  updatedAt        DateTime @updatedAt
}
